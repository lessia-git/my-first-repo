{
  "consumer": {
    "name": "HW13PetstoreConsumer"
  },
  "interactions": [
    {
      "description": "a request for pet 1",
      "providerState": "pet with id 1 exists",
      "request": {
        "headers": {
          "Accept": "application/json"
        },
        "method": "GET",
        "path": "/v2/pet/1"
      },
      "response": {
        "body": {
          "category": {
            "id": 1,
            "name": "cats"
          },
          "id": 1,
          "name": "Garfield",
          "photoUrls": [
            "https://example.com/image.jpg"
          ],
          "status": "available",
          "tags": [
            {
              "id": 1,
              "name": "cute"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "$.body": {
            "match": "type"
          },
          "$.body.photoUrls": {
            "match": "type",
            "min": 1
          },
          "$.body.tags": {
            "match": "type",
            "min": 1
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "14.0.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "2.0.0"
    }
  },
  "provider": {
    "name": "PetstoreProvider"
  }
}