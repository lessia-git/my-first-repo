          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test('Response is JSON object', () => {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "pm.test('Has id, type, setup, punchline', () => {\r",
